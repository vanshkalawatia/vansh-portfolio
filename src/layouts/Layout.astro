---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Vansh Kalawatia - Backend Developer Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-neo-bg text-neo-text font-sans selection:bg-neo-accent selection:text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col lg:flex-row gap-8 lg:gap-16 relative">
				<Sidebar />
				<main class="flex-1 py-12 lg:py-24 space-y-24 min-w-0">
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>
