---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Layout title={`${entry.data.title} | Vansh Kalawatia`}>
  <div class="mb-8">
    <a href="/#blog" class="inline-block border-4 border-black px-4 py-2 font-black uppercase shadow-neo-sm hover:translate-y-1 hover:shadow-none transition-all bg-white mb-8">
      &larr; Back to Home
    </a>
  </div>
  <article class="prose prose-lg max-w-none prose-headings:font-black prose-a:text-neo-accent prose-a:font-bold prose-img:border-4 prose-img:border-black prose-img:shadow-neo">
    <div class="mb-8 border-b-4 border-black pb-8">
      <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tight mb-4">{entry.data.title}</h1>
      <div class="flex flex-wrap gap-4 items-center">
        <span class="border-2 border-black px-3 py-1 bg-neo-bg font-bold shadow-neo-sm">
          {entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
        <div class="flex gap-2">
          {entry.data.tags.map((tag: string) => (
            <span class="border-2 border-black px-3 py-1 bg-neo-accent text-white font-bold shadow-neo-sm uppercase">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
    
    <div class="bg-white border-4 border-black p-6 sm:p-12 shadow-neo-lg">
      <Content />
    </div>
  </article>
</Layout>
