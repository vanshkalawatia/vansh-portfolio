---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Activity from '../components/Activity.astro';
import BlogFeed from '../components/BlogFeed.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Vansh Kalawatia | Backend Developer">
  <Hero />
  <Experience />
  <Projects />
  <Activity />
  <BlogFeed />
  <Contact />
  
  <div class="mt-24 mb-12 flex justify-center">
    <a href="/dark-side" class="group relative inline-block bg-black text-[#00ff00] font-mono font-black text-xl px-12 py-6 border-4 border-[#00ff00] shadow-[8px_8px_0_0_#00ff00] hover:translate-y-1 hover:translate-x-1 hover:shadow-[4px_4px_0_0_#00ff00] active:translate-y-2 active:translate-x-2 active:shadow-none transition-all uppercase tracking-widest overflow-hidden">
      <span class="relative z-10 flex items-center gap-3">
        Enter the Dark Side
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  </div>
</Layout>
