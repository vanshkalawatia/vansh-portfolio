---
const navLinks = [
  { name: 'Education & Exp', href: '#experience' },
  { name: 'Projects', href: '#projects' },
  { name: 'Activity', href: '#activity' },
  { name: 'Blog', href: '#blog' },
  { name: 'Contact', href: '#contact' },
];
---

<aside class="sticky top-0 z-50 bg-neo-bg lg:h-screen lg:w-64 pt-6 lg:pt-24 pb-4 lg:pb-12 flex flex-col justify-between border-b-4 border-neo-border lg:border-none mb-8 lg:mb-0">
  <div class="flex flex-col gap-4 lg:gap-8">
    <div class="flex justify-between items-center lg:items-start">
      <a href="/" class="block">
        <h1 class="text-3xl lg:text-4xl font-black tracking-tight border-b-4 border-neo-border inline-block mb-1">VK.</h1>
        <p class="hidden lg:block text-lg font-bold text-neo-accent uppercase tracking-wider">Backend Dev</p>
      </a>
      
      <button id="theme-toggle" class="p-2 border-2 border-neo-border bg-neo-card shadow-neo-sm hover:translate-y-1 hover:shadow-none transition-all">
        <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
        <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
      </button>
    </div>
    
    <nav class="flex flex-row lg:flex-col gap-3 lg:gap-0 lg:space-y-4 overflow-x-auto pb-2 lg:pb-0 scrollbar-hide">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="flex-shrink-0 block text-xs sm:text-sm lg:text-xl font-bold uppercase lg:hover:translate-x-2 transition-transform w-max hover:text-neo-accent border-2 border-neo-border lg:border-none px-3 py-1.5 lg:px-0 lg:py-0 bg-neo-card lg:bg-transparent shadow-neo-sm lg:shadow-none"
        >
          {link.name}
        </a>
      ))}
    </nav>
  </div>
  
  <div class="hidden lg:block mt-12">
    <a href="https://linkedin.com/in/vanshkalawatia" target="_blank" class="block border-4 border-neo-border p-3 bg-[#0a66c2] text-white shadow-neo-sm transform -rotate-2 hover:-translate-y-1 hover:rotate-0 hover:shadow-neo transition-all">
      <div class="flex items-center gap-2 mb-1">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path></svg>
        <p class="font-black text-sm uppercase tracking-wide">Open to work</p>
      </div>
      <p class="text-xs font-bold opacity-90 pl-6">Based in India</p>
    </a>
  </div>
</aside>

<script>
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

  if (themeToggleDarkIcon && themeToggleLightIcon) {
    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        themeToggleLightIcon.classList.remove('hidden');
    } else {
        themeToggleDarkIcon.classList.remove('hidden');
    }
  }

  const themeToggleBtn = document.getElementById('theme-toggle');

  if (themeToggleBtn && themeToggleDarkIcon && themeToggleLightIcon) {
    themeToggleBtn.addEventListener('click', function() {
        themeToggleDarkIcon.classList.toggle('hidden');
        themeToggleLightIcon.classList.toggle('hidden');

        if (localStorage.getItem('theme')) {
            if (localStorage.getItem('theme') === 'light') {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            } else {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            }
        } else {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }
    });
  }
</script>
