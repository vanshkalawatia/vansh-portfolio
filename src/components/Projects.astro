---
import projects from '../data/projects.json';
---
<section id="projects" class="scroll-mt-24">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-4xl font-black uppercase tracking-tight">Projects</h2>
    <div class="h-2 flex-1 bg-neo-border mt-2"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    {projects.map((project) => (
      <div class="bg-neo-card border-4 border-neo-border p-6 sm:p-8 flex flex-col shadow-neo transform transition-transform hover:-translate-y-2 hover:shadow-neo-lg">
        <div class="flex flex-wrap gap-2 mb-4">
          {project.tags.map((tag) => (
            <span class="border-2 border-neo-border px-3 py-1 bg-neo-bg text-sm font-bold shadow-neo-sm uppercase">
              {tag}
            </span>
          ))}
        </div>
        
        <h3 class="text-2xl font-black mb-3">{project.title}</h3>
        <p class="text-lg font-medium mb-6 flex-1">
          {project.description}
        </p>
        
        <div class="flex gap-4 mt-auto">
          {project.github && project.github !== '' && (
            <a href={project.github} target="_blank" class="flex-1 text-center border-4 border-neo-border py-3 font-black uppercase hover:bg-neo-text hover:text-neo-bg transition-colors shadow-neo-sm flex items-center justify-center gap-2">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
              <span>Source</span>
            </a>
          )}
          {project.link && project.link !== '' && (
            <a href={project.link} target="_blank" class="flex-1 text-center border-4 border-neo-border py-3 font-black uppercase hover:bg-neo-text hover:text-neo-bg transition-colors shadow-neo-sm flex items-center justify-center gap-2">
              <span>Visit Site</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
