---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<section id="blog" class="scroll-mt-24">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-4xl font-black uppercase tracking-tight">Articles</h2>
    <div class="h-2 flex-1 bg-black mt-2"></div>
  </div>

  <div class="space-y-6">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="block bg-white border-4 border-black p-6 sm:p-8 shadow-neo hover:-translate-y-1 hover:shadow-neo-lg transition-all group">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4 gap-2">
          <h3 class="text-2xl font-black group-hover:text-neo-accent transition-colors">{post.data.title}</h3>
          <span class="inline-block border-2 border-black px-3 py-1 bg-neo-bg font-bold text-sm whitespace-nowrap shadow-neo-sm">
            {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
        </div>
        <p class="text-lg font-medium mb-6">
          {post.data.description}
        </p>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="border-2 border-black px-3 py-1 bg-gray-100 text-sm font-bold shadow-neo-sm uppercase tracking-wide">
              {tag}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
</section>
