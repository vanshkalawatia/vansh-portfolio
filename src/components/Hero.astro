<section id="hero" class="scroll-mt-24">
  <div class="border-4 border-neo-border p-8 sm:p-12 bg-neo-card shadow-neo">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center lg:items-start">
      <div class="flex-shrink-0">
        <div class="w-48 h-48 lg:w-64 lg:h-64 border-4 border-neo-border shadow-neo-sm overflow-hidden bg-neo-accent">
          <img src="/images/avatar.png" alt="Vansh Kalawatia" class="w-full h-full object-cover bg-neo-bg" />
        </div>
      </div>
      
      <div class="flex-1 text-center lg:text-left">
        <h2 class="text-5xl md:text-7xl font-black mb-2 tracking-tighter uppercase leading-none">Vansh</h2>
        <h2 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter uppercase text-neo-accent leading-none">Kalawatia</h2>
        
        <div class="inline-block text-xl md:text-2xl font-bold mb-6 border-l-4 lg:border-l-0 lg:border-l-4 border-neo-border pl-4 text-left">
          B.Tech CS '28 | Backend Focus on scalable APIs, microservices, and databases.
        </div>
        
        <p class="text-lg mb-8 max-w-2xl font-medium leading-relaxed text-left">
          Actively studying Go—prioritizing core language mechanics, memory management, and data structures before scaling to distributed system architecture.
        </p>
        
        <div class="flex justify-center lg:justify-start">
          <a 
            href="/resume.pdf" 
            target="_blank"
            class="inline-block bg-neo-accent text-white font-black text-xl px-8 py-4 border-4 border-neo-border shadow-neo hover:translate-y-1 hover:shadow-neo-sm active:translate-y-2 active:shadow-none transition-all uppercase"
          >
            Résumé
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
