---
const timeline = [
  {
    role: 'Backend Developer (Go)',
    company: 'Projects & Open Source',
    period: '2023 - Present',
    description: 'Building microservices, REST/gRPC APIs, and optimizing database queries using PostgreSQL and Redis.',
    tags: ['Go', 'PostgreSQL', 'Docker', 'Redis']
  },
  {
    role: 'Bachelor of Technology (B.Tech)',
    company: 'Computer Science Engineering',
    period: 'Graduated',
    description: 'Focused on Data Structures, Algorithms, Operating Systems, and Database Management Systems. Strong foundation in core CS principles.',
    tags: ['CS Core', 'System Design']
  }
];
---
<section id="experience" class="scroll-mt-24">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-4xl font-black uppercase tracking-tight">Experience & Education</h2>
    <div class="h-2 flex-1 bg-black mt-2"></div>
  </div>

  <div class="space-y-12 pl-4 border-l-4 border-black ml-4">
    {timeline.map((item) => (
      <div class="relative pl-8">
        <div class="absolute -left-3.5 top-2 w-6 h-6 bg-neo-accent border-4 border-black rounded-none shadow-neo-sm"></div>
        <div class="bg-white border-4 border-black p-6 sm:p-8 shadow-neo transform transition-transform hover:-translate-y-1 hover:shadow-neo-lg">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4">
            <div>
              <h3 class="text-2xl font-black mb-1">{item.role}</h3>
              <p class="text-xl font-bold text-gray-700">{item.company}</p>
            </div>
            <span class="inline-block border-2 border-black px-4 py-1.5 bg-neo-bg font-bold mt-4 sm:mt-0 whitespace-nowrap shadow-neo-sm uppercase">
              {item.period}
            </span>
          </div>
          <p class="text-lg font-medium mb-6">
            {item.description}
          </p>
          <div class="flex flex-wrap gap-3">
            {item.tags.map((tag) => (
              <span class="border-2 border-black px-3 py-1 bg-neo-accent text-white text-sm font-bold shadow-neo-sm uppercase tracking-wide">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
